{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "start": "bun run dist/index.js",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "@hono/node-server": "^1.11.0",
    "pg": "^8.12.0",
    "drizzle-orm": "^0.31.0",
    "minio": "^8.0.0",
    "amqplib": "^0.10.4",
    "redis": "^4.6.14",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@types/amqplib": "^0.10.5",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.22.0",
    "typescript": "^5.5.0"
  }
}
